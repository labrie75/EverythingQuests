package-as: EverythingQuests

# CurseForge project ID (https://www.curseforge.com/wow/addons/everythingquests)
curse-id: 1544648

enable-nolib-creation: no

changelog-title: Everything Quests
manual-changelog:
  filename: .release_changelog.md
  markup-type: markdown

ignore:
  - .pkgmeta
  - .github
  - .gitignore
  - README.md
  - CHANGELOG.md
  - .vscode
  - screenshots
  - LICENSE
  - claude.md
  - .claude
  - .luarc.json
  - .release_changelog.md
