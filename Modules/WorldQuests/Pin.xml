<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
    <Button name="EQWorldQuestPinTemplate" mixin="EQWorldQuestPinMixin" hidden="true" virtual="true">
        <Size x="34" y="34"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="ring">
                    <Anchors><Anchor point="CENTER"/></Anchors>
                    <Size x="34" y="34"/>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <Texture parentKey="icon">
                    <Anchors><Anchor point="CENTER"/></Anchors>
                    <Size x="22" y="22"/>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString parentKey="timeText" inherits="GameFontWhiteSmall" text="">
                    <Anchors>
                        <Anchor point="TOP" relativePoint="BOTTOM" x="0" y="-1"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Button>
</Ui>
