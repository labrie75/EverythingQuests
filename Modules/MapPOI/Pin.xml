<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
    <!--
        EQQuestPinTemplate — virtual button used by Modules/MapPOI/Provider.
        Layered visual: ring background (BACKGROUND) + center icon (ARTWORK)
        + numberText overlay. The mixin (Pin.lua) tints the ring per-quest so
        ours is visually distinct from Blizzard's plain yellow `!`/`?` pins
        even when stacked at the same coords.

        No <Scripts>: MapCanvasMixin:AcquirePin auto-wires OnEnter/OnLeave/
        OnClick to the mixin's same-named methods on first acquisition.
    -->
    <Button name="EQQuestPinTemplate" mixin="EQQuestPinMixin" hidden="true" virtual="true">
        <Size x="28" y="28"/>
        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="ring">
                    <Anchors><Anchor point="CENTER"/></Anchors>
                    <Size x="28" y="28"/>
                </Texture>
            </Layer>
            <Layer level="ARTWORK">
                <Texture parentKey="icon">
                    <Anchors><Anchor point="CENTER"/></Anchors>
                    <Size x="18" y="18"/>
                </Texture>
            </Layer>
            <Layer level="OVERLAY">
                <FontString parentKey="numberText" inherits="GameFontNormalSmall" text="">
                    <Anchors><Anchor point="CENTER"/></Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Button>
</Ui>
